generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppMeta {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kunde {
  id              Int      @id @default(autoincrement())
  typ             String
  name            String
  firmenname      String?
  ustId           String?
  email           String?
  instagramHandle String?
  adresse         String?
  zahlungsziel    Int?
  stammkunde      Boolean  @default(false)
  vorlieben       String?
  hauttyp         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bestellungen Bestellung[]

  @@index([typ])
  @@index([stammkunde])
}

model Produkt {
  id                     Int      @id @default(autoincrement())
  name                   String
  kategorie              String
  vegan                  Boolean  @default(false)
  inhaltsstoffe          String?
  allergene              String?
  preisB2c               Decimal
  preisB2b               Decimal
  b2cPuffermenge         Decimal
  standardMhdDauerMonate Int
  inAboBoxEnthalten      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  chargen Charge[]
  bestellpositionen Bestellposition[]

  @@index([kategorie])
  @@index([vegan])
  @@index([inAboBoxEnthalten])
}

model Bestellung {
  id             Int      @id @default(autoincrement())
  kundeId        Int
  datum          DateTime
  kanal          String
  lieferadresse  String?
  allergeneBestaetigtAm DateTime?
  zahlungsstatus String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  kunde Kunde @relation(fields: [kundeId], references: [id])
  positionen Bestellposition[]
  pakete Paket[]

  @@index([kundeId])
  @@index([kanal])
  @@index([zahlungsstatus])
  @@index([status])
  @@index([datum])
  @@index([allergeneBestaetigtAm])
}

model Mitarbeiter {
  id             Int      @id @default(autoincrement())
  name           String
  rolle          String
  zugriffsrechte String?
  email          String?
  telefonnummer  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  chargen Charge[]
  pakete Paket[]

  @@index([rolle])
}

model Paket {
  id             Int       @id @default(autoincrement())
  bestellungId   Int
  mitarbeiterId  Int
  versandoption  String
  versandkosten  Decimal
  status         String
  versanddatum   DateTime?
  trackingnummer String?
  zustelldatum   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bestellung  Bestellung  @relation(fields: [bestellungId], references: [id])
  mitarbeiter Mitarbeiter @relation(fields: [mitarbeiterId], references: [id])

  @@index([bestellungId])
  @@index([mitarbeiterId])
  @@index([status])
  @@index([versanddatum])
  @@index([zustelldatum])
}

model Charge {
  id                  Int      @id @default(autoincrement())
  produktId           Int
  mitarbeiterId       Int
  herstellungsdatum   DateTime
  mhd                 DateTime
  produzierteMenge    Int
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  produkt     Produkt     @relation(fields: [produktId], references: [id])
  mitarbeiter Mitarbeiter @relation(fields: [mitarbeiterId], references: [id])
  lagerbestaende Lagerbestand[]
  bestellpositionen Bestellposition[]
  verkaufseventPositionen VerkaufseventPosition[]

  @@index([produktId])
  @@index([mitarbeiterId])
  @@index([mhd])
  @@index([status])
}

model Verkaufsevent {
  id        Int      @id @default(autoincrement())
  datum     DateTime
  ort       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positionen VerkaufseventPosition[]

  @@index([datum])
}

model VerkaufseventPosition {
  id                 Int      @id @default(autoincrement())
  verkaufseventId    Int
  chargeId           Int
  mengeMitgenommen   Int
  mengeVerkauft      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  verkaufsevent Verkaufsevent @relation(fields: [verkaufseventId], references: [id])
  charge        Charge        @relation(fields: [chargeId], references: [id])

  @@unique([verkaufseventId, chargeId])
  @@index([verkaufseventId])
  @@index([chargeId])
}

model Bestellposition {
  id           Int      @id @default(autoincrement())
  bestellungId Int
  produktId    Int
  chargeId     Int
  menge        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bestellung Bestellung @relation(fields: [bestellungId], references: [id])
  produkt    Produkt    @relation(fields: [produktId], references: [id])
  charge     Charge     @relation(fields: [chargeId], references: [id])

  @@index([bestellungId])
  @@index([produktId])
  @@index([chargeId])
}

model Lagerbestand {
  id                              Int      @id @default(autoincrement())
  chargeId                        Int
  lagerort                        String
  mengeVoruebergehendReserviert   Int      @default(0)
  mengeVerbindlichReserviert      Int      @default(0)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  charge Charge @relation(fields: [chargeId], references: [id])

  @@unique([chargeId, lagerort])
  @@index([chargeId])
  @@index([lagerort])
}
