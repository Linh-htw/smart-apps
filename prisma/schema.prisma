generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppMeta {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kunde {
  id              Int      @id @default(autoincrement())
  typ             String
  name            String
  firmenname      String?
  ustId           String?
  email           String?
  instagramHandle String?
  adresse         String?
  zahlungsziel    Int?
  stammkunde      Boolean  @default(false)
  vorlieben       String?
  hauttyp         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bestellungen Bestellung[]

  @@index([typ])
  @@index([stammkunde])
}

model Produkt {
  id                     Int      @id @default(autoincrement())
  name                   String
  kategorie              String
  vegan                  Boolean  @default(false)
  inhaltsstoffe          String?
  allergene              String?
  preisB2c               Decimal
  preisB2b               Decimal
  b2cPuffermenge         Decimal
  standardMhdDauerMonate Int
  inAboBoxEnthalten      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  chargen Charge[]

  @@index([kategorie])
  @@index([vegan])
  @@index([inAboBoxEnthalten])
}

model Bestellung {
  id             Int      @id @default(autoincrement())
  kundeId        Int
  datum          DateTime
  kanal          String
  lieferadresse  String?
  zahlungsstatus String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  kunde Kunde @relation(fields: [kundeId], references: [id])

  @@index([kundeId])
  @@index([kanal])
  @@index([zahlungsstatus])
  @@index([status])
  @@index([datum])
}

model Mitarbeiter {
  id             Int      @id @default(autoincrement())
  name           String
  rolle          String
  zugriffsrechte String?
  email          String?
  telefonnummer  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  chargen Charge[]

  @@index([rolle])
}

model Charge {
  id                  Int      @id @default(autoincrement())
  produktId           Int
  mitarbeiterId       Int
  herstellungsdatum   DateTime
  mhd                 DateTime
  produzierteMenge    Int
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  produkt     Produkt     @relation(fields: [produktId], references: [id])
  mitarbeiter Mitarbeiter @relation(fields: [mitarbeiterId], references: [id])

  @@index([produktId])
  @@index([mitarbeiterId])
  @@index([mhd])
  @@index([status])
}
