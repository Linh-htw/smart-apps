generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppMeta {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kunde {
  id              Int      @id @default(autoincrement())
  typ             String
  name            String
  firmenname      String?
  ustId           String?
  email           String?
  instagramHandle String?
  adresse         String?
  zahlungsziel    Int?
  stammkunde      Boolean  @default(false)
  vorlieben       String?
  hauttyp         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([typ])
  @@index([stammkunde])
}
